# 百度千帆 API Key（必需，用于 API 模式）
BAIDU_API_KEY=your-qianfan-api-key

# 搜索模式: api | crawler | auto（默认: auto）
BAIDU_SEARCH_MODE=auto

# 请求超时时间，单位秒（默认: 30）
BAIDU_SEARCH_TIMEOUT=30

# 重试次数（默认: 3）
BAIDU_SEARCH_RETRY_COUNT=3

# npm 发布（仅本地使用，不要提交真实值）
NPM_PUBLISH_TOKEN=your-npm-publish-token
NPM_REGISTRY_URL=https://registry.npmjs.org/

# GitHub 推送可选项
GITHUB_RELEASE_REPO=https://github.com/z-imagine/openclaw-baidu-search.git
GITHUB_RELEASE_BRANCH=main
# GITHUB_RELEASE_MESSAGE=release: @z-imagine/openclaw-baidu-search@1.0.2

# ClawHub 发布可选项
CLAWHUB_PACKAGE_TAGS=latest
CLAWHUB_SOURCE_REPO=z-imagine/openclaw-baidu-search
CLAWHUB_SOURCE_PATH=.
# 默认发布 main；如不显式设置 commit，脚本会自动解析该分支当前最新 SHA
CLAWHUB_SOURCE_REF=main
# CLAWHUB_CHANGELOG=Release notes here
# CLAWHUB_SOURCE_COMMIT=
