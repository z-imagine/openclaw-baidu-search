# 百度千帆 API Key（必需，用于 API 模式）
BAIDU_API_KEY=your-qianfan-api-key

# 搜索模式: api | crawler | auto（默认: auto）
BAIDU_SEARCH_MODE=auto

# 请求超时时间，单位秒（默认: 30）
BAIDU_SEARCH_TIMEOUT=30

# 重试次数（默认: 3）
BAIDU_SEARCH_RETRY_COUNT=3

# npm 发布（仅本地使用，不要提交真实值）
NPM_PUBLISH_TOKEN=your-npm-publish-token
NPM_REGISTRY_URL=https://registry.npmjs.org/
